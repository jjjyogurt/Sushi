GEMINI_API_KEY=replace_with_rotated_key
GEMINI_MODEL_ANALYSIS=gemini-3-flash
GEMINI_MODEL_CHAT=gemini-3-flash

# development | production (production enables secure cookies and disables /auth/users unless overridden)
ENVIRONMENT=development
# Force Secure cookies when true (also enabled when ENVIRONMENT=production)
SECURE_COOKIES=false
# When set, overrides default: in production user list is off unless AUTH_ALLOW_USER_ENUMERATION=true
# AUTH_ALLOW_USER_ENUMERATION=true

# Local SQLite (default)
DATABASE_URL=sqlite:///./sushi.db
# Production Cloud Run uses Supabase PostgreSQL through the session pooler.
# DATABASE_URL=postgresql+psycopg2://postgres.PROJECT_REF:PASSWORD@HOST:5432/postgres?sslmode=require

# Firebase Hosting rewrites expect a Cloud Run service named sushi-backend (see firebase.json).
ENABLE_MOCK_DISCOVERY=false
TRANSCRIPT_LANGUAGES=en,de,es,fr,it,ja,ko,zh-Hans
YOUTUBE_TRANSCRIPT_API_KEY=replace_with_youtubetranscript_dev_key
YOUTUBE_TRANSCRIPT_BASE_URL=https://www.youtubetranscript.dev/api/v2
YOUTUBE_TRANSCRIPT_TIMEOUT_SECONDS=30
YOUTUBE_TRANSCRIPT_MAX_RETRIES=1
YOUTUBE_DATA_API_KEY=replace_with_youtube_data_api_key
YOUTUBE_COMMENTS_TIMEOUT_SECONDS=30
YOUTUBE_COMMENTS_MAX_RETRIES=2
YOUTUBE_COMMENTS_PAGE_SIZE=100
YOUTUBE_COMMENTS_MAX_PAGES=200
YOUTUBE_COMMENTS_MAX_REPLY_PAGES=20
ANALYSIS_MAX_TRANSCRIPT_CHARS=3000000
ANALYSIS_SINGLE_PASS_MAX_ESTIMATED_TOKENS=750000
ANALYSIS_ESTIMATED_CHARS_PER_TOKEN=4
ANALYSIS_CHUNK_CHARS=12000
ANALYSIS_CHUNK_OVERLAP_CHARS=1200
ANALYSIS_MAX_CHUNKS=12
CHAT_MAX_CONTEXT_CHARS=24000

# Request-triggered async analysis worker (Cloud Tasks -> private Cloud Run worker)
# Leave blank locally to skip worker wake tasks.
GCP_PROJECT_ID=sushi-d9036
GCP_REGION=asia-southeast1
ANALYSIS_WORKER_URL=
ANALYSIS_WORKER_TASKS_QUEUE=sushi-analysis-worker
ANALYSIS_WORKER_TASK_SERVICE_ACCOUNT_EMAIL=
# Optional defense-in-depth header for the internal worker drain endpoint.
# Store the production value in Secret Manager / Cloud Run secrets, not in git.
ANALYSIS_WORKER_INTERNAL_TOKEN=
ANALYSIS_WORKER_DRAIN_PATH=/internal/analysis-worker/drain
ANALYSIS_WORKER_DISPATCH_DEADLINE_SECONDS=1800
ANALYSIS_WORKER_DRAIN_MAX_SECONDS=1200
